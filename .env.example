# ── Sentinel Pipeline Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# GitHub Personal Access Token (repo scope required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Target repository in "owner/repo" format
GITHUB_REPO=your-username/your-repo

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Docker sandbox image name
SANDBOX_IMAGE=sentinel-sandbox:latest
# Max seconds a sandbox container may run before being killed
SANDBOX_TIMEOUT_SECONDS=60

# Maximum fix attempts before giving up on a crash event
MAX_FIX_ATTEMPTS=3

# Groq API Key for LLM SRE Agent (console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
